---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const artifacts = (await getCollection('artifacts')).sort(
  (a, b) => b.data.dateAdded.getTime() - a.data.dateAdded.getTime(),
);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Library — ai-features" description="A growing collection of prompts, skills, hooks, and other AI-tooling artifacts.">
  <section class="mb-10">
    <h1 class="text-3xl font-semibold tracking-tight text-neutral-50 sm:text-4xl">
      Library
    </h1>
    <p class="mt-3 max-w-prose text-neutral-400">
      Prompts, skills, hooks, slash commands, subagents, settings snippets, and
      playbooks — collected from the digest and ready to drop into your setup.
    </p>
  </section>

  <section>
    <h2 class="mb-4 font-mono text-xs uppercase tracking-wider text-neutral-500">
      {artifacts.length} artifact{artifacts.length === 1 ? '' : 's'}
    </h2>
    <ul class="grid gap-4 sm:grid-cols-2">
      {artifacts.map((artifact) => (
        <li>
          <a
            href={`${base}/artifacts/${artifact.id}`}
            class="group block h-full rounded-md border border-neutral-800 bg-neutral-900/40 p-4 transition hover:border-emerald-500/60 hover:bg-neutral-900"
          >
            <div class="flex items-center justify-between gap-2">
              <span class="rounded-sm border border-emerald-500/40 bg-emerald-500/10 px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wider text-emerald-300">
                {artifact.data.type}
              </span>
              <span class="font-mono text-[10px] uppercase tracking-wider text-neutral-500">
                {artifact.data.topic}
              </span>
            </div>
            <h3 class="mt-3 font-medium text-neutral-100 group-hover:text-emerald-400">
              {artifact.data.title}
            </h3>
            <p class="mt-2 text-sm text-neutral-400">{artifact.data.summary}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
