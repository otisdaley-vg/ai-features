---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const issues = (await getCollection('issues')).sort(
  (a, b) => b.data.issueNumber - a.data.issueNumber,
);
const latestIssue = issues[0];

const SEVEN_DAYS_MS = 7 * 24 * 60 * 60 * 1000;
const now = Date.now();

const recentArtifacts = (await getCollection('artifacts'))
  .sort((a, b) => b.data.dateAdded.getTime() - a.data.dateAdded.getTime())
  .slice(0, 8)
  .map((artifact) => ({
    artifact,
    isNew: now - artifact.data.dateAdded.getTime() <= SEVEN_DAYS_MS,
  }));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title="ai-features — AI tooling digest and library"
  description="A digest of AI features, tooling experiments, and a library of prompts, skills, hooks, and more."
>
  <section class="mb-12">
    <h1 class="text-3xl font-semibold tracking-tight text-neutral-950 sm:text-4xl dark:text-neutral-50">
      ai-features
    </h1>
    <p class="mt-3 max-w-prose text-neutral-600 dark:text-neutral-400">
      A digest of AI features, tooling experiments, and a growing library of
      prompts, skills, hooks, and other artifacts to drop into your setup.
    </p>
  </section>

  {latestIssue && (
    <section class="mb-14">
      <h2 class="mb-3 font-mono text-xs uppercase tracking-wider text-neutral-500">
        Latest issue
      </h2>
      <a
        href={`${base}/issues/${latestIssue.data.issueNumber}`}
        class="group block rounded-md border border-neutral-200 bg-white p-6 transition hover:border-emerald-500/60 hover:shadow-sm dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:bg-neutral-900"
      >
        <div class="flex items-baseline gap-3 font-mono text-xs text-neutral-500">
          <span class="text-emerald-600 dark:text-emerald-400">
            #{String(latestIssue.data.issueNumber).padStart(3, '0')}
          </span>
          <time datetime={latestIssue.data.date.toISOString()}>
            {dateFormatter.format(latestIssue.data.date)}
          </time>
        </div>
        <h3 class="mt-3 text-2xl font-semibold tracking-tight text-neutral-900 group-hover:text-emerald-600 sm:text-3xl dark:text-neutral-50 dark:group-hover:text-emerald-400">
          {latestIssue.data.title}
        </h3>
        <p class="mt-3 max-w-prose text-neutral-600 dark:text-neutral-400">
          {latestIssue.data.summary}
        </p>
        <span class="mt-5 inline-flex items-center gap-1 font-mono text-sm text-emerald-600 group-hover:underline dark:text-emerald-400">
          Read full issue <span aria-hidden="true">→</span>
        </span>
      </a>
    </section>
  )}

  {recentArtifacts.length > 0 && (
    <section class="mb-12">
      <div class="mb-4 flex items-baseline justify-between gap-4">
        <h2 class="font-mono text-xs uppercase tracking-wider text-neutral-500">
          Recent artifacts
        </h2>
        <a
          href={`${base}/library`}
          class="font-mono text-xs text-neutral-500 hover:text-emerald-600 dark:hover:text-emerald-400"
        >
          Browse library →
        </a>
      </div>
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {recentArtifacts.map(({ artifact, isNew }) => (
          <li>
            <a
              href={`${base}/artifacts/${artifact.id}`}
              class="group flex h-full flex-col rounded-md border border-neutral-200 bg-white p-4 transition hover:border-emerald-500/60 hover:shadow-sm dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:bg-neutral-900"
            >
              <div class="flex items-center justify-between gap-2">
                <span class="rounded-sm border border-emerald-500/40 bg-emerald-500/10 px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wider text-emerald-700 dark:text-emerald-300">
                  {artifact.data.type}
                </span>
                {isNew && (
                  <span class="rounded-sm border border-amber-500/40 bg-amber-500/10 px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wider text-amber-700 dark:text-amber-300">
                    New
                  </span>
                )}
              </div>
              <h3 class="mt-3 font-medium text-neutral-900 group-hover:text-emerald-600 dark:text-neutral-100 dark:group-hover:text-emerald-400">
                {artifact.data.title}
              </h3>
              <div class="mt-1 font-mono text-[10px] uppercase tracking-wider text-neutral-500">
                {artifact.data.topic}
              </div>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
                {artifact.data.summary}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
