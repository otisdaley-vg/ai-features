---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const issues = await getCollection('issues');
  return issues.map((issue) => ({
    params: { issueNumber: String(issue.data.issueNumber) },
    props: { issue },
  }));
}

type Props = { issue: CollectionEntry<'issues'> };
const { issue } = Astro.props;
const { Content } = await render(issue);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? '';
const ogImage = `${siteOrigin}${base}/og/issues/${issue.data.issueNumber}.png`;
---

<Layout
  title={`#${issue.data.issueNumber} — ${issue.data.title}`}
  description={issue.data.summary}
  ogImage={ogImage}
>
  <article>
    <a href={base || '/'} class="font-mono text-xs text-neutral-500 hover:text-emerald-400">
      ← back to issues
    </a>

    <header class="mt-4 mb-8 border-b border-neutral-800 pb-6">
      <div class="font-mono text-xs uppercase tracking-wider text-emerald-400">
        Issue #{String(issue.data.issueNumber).padStart(3, '0')}
        {' · '}
        <time datetime={issue.data.date.toISOString()}>
          {issue.data.date.toISOString().slice(0, 10)}
        </time>
      </div>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-neutral-50 sm:text-4xl">
        {issue.data.title}
      </h1>
      <p class="mt-3 max-w-prose text-neutral-400">{issue.data.summary}</p>
      <div class="mt-3 font-mono text-xs text-neutral-500">
        Editors: {issue.data.editors.join(', ')}
      </div>
      {issue.data.topicsCovered && issue.data.topicsCovered.length > 0 && (
        <ul class="mt-3 flex flex-wrap gap-2">
          {issue.data.topicsCovered.map((topic) => (
            <li class="rounded-sm border border-neutral-800 bg-neutral-900 px-2 py-0.5 font-mono text-xs text-neutral-400">
              {topic}
            </li>
          ))}
        </ul>
      )}
    </header>

    <div class="prose prose-invert prose-neutral max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-h2:mt-10 prose-h2:border-b prose-h2:border-neutral-800 prose-h2:pb-2 prose-a:text-emerald-400 prose-a:no-underline hover:prose-a:underline prose-code:rounded prose-code:bg-neutral-900 prose-code:px-1 prose-code:py-0.5 prose-code:text-emerald-300 prose-code:before:content-none prose-code:after:content-none prose-pre:bg-neutral-900 prose-pre:border prose-pre:border-neutral-800">
      <Content />
    </div>
  </article>
</Layout>
