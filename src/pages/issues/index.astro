---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const issues = (await getCollection('issues')).sort(
  (a, b) => b.data.issueNumber - a.data.issueNumber,
);

const allTopics = Array.from(
  new Set(issues.flatMap((issue) => issue.data.topicsCovered ?? [])),
).sort();

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Issues — ai-features" description="Every issue of the AI Features digest, filterable by topic.">
  <section class="mb-8">
    <h1 class="text-3xl font-semibold tracking-tight text-neutral-50 sm:text-4xl">
      Issues
    </h1>
    <p class="mt-3 max-w-prose text-neutral-400">
      Every issue, newest first. Click a topic to filter.
    </p>
  </section>

  {allTopics.length > 0 && (
    <section class="mb-8" aria-label="Topic filters">
      <div class="mb-2 flex items-center justify-between">
        <h2 class="font-mono text-xs uppercase tracking-wider text-neutral-500">
          Filter by topic
        </h2>
        <button
          type="button"
          id="clear-filters"
          class="hidden font-mono text-xs text-neutral-500 hover:text-emerald-400"
        >
          clear ×
        </button>
      </div>
      <ul id="topic-filters" class="flex flex-wrap gap-2">
        {allTopics.map((topic) => (
          <li>
            <button
              type="button"
              data-topic={topic}
              class="topic-chip rounded-sm border border-neutral-800 bg-neutral-900 px-2 py-0.5 font-mono text-xs text-neutral-400 hover:border-emerald-500/50 hover:text-emerald-400 data-[active]:border-emerald-400 data-[active]:bg-emerald-500/10 data-[active]:text-emerald-300"
            >
              {topic}
            </button>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section>
    <ul id="issue-list" class="divide-y divide-neutral-800 border-y border-neutral-800">
      {issues.map((issue) => (
        <li
          class="issue-row py-4"
          data-topics={(issue.data.topicsCovered ?? []).join(',')}
        >
          <div class="flex items-baseline gap-4">
            <a
              href={`${base}/issues/${issue.data.issueNumber}`}
              class="font-mono text-sm text-emerald-400 hover:underline"
            >
              #{String(issue.data.issueNumber).padStart(3, '0')}
            </a>
            <div class="flex-1">
              <a
                href={`${base}/issues/${issue.data.issueNumber}`}
                class="font-medium text-neutral-100 hover:text-emerald-400"
              >
                {issue.data.title}
              </a>
              <div class="mt-1 text-sm text-neutral-400">{issue.data.summary}</div>
              <div class="mt-1 font-mono text-xs text-neutral-500">
                <time datetime={issue.data.date.toISOString()}>
                  {issue.data.date.toISOString().slice(0, 10)}
                </time>
              </div>
              {issue.data.topicsCovered && issue.data.topicsCovered.length > 0 && (
                <ul class="mt-2 flex flex-wrap gap-1.5">
                  {issue.data.topicsCovered.map((topic) => (
                    <li class="rounded-sm border border-neutral-800 bg-neutral-900 px-1.5 py-0.5 font-mono text-[0.65rem] uppercase tracking-wider text-neutral-500">
                      {topic}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        </li>
      ))}
    </ul>
    <div
      id="empty-state"
      class="hidden py-12 text-center font-mono text-sm text-neutral-500"
    >
      No issues match the selected topics.
    </div>
  </section>
</Layout>

<script is:inline>
  (() => {
    const chips = document.querySelectorAll('.topic-chip');
    const rows = document.querySelectorAll('.issue-row');
    const empty = document.getElementById('empty-state');
    const clearBtn = document.getElementById('clear-filters');
    const selected = new Set();

    function apply() {
      let visible = 0;
      rows.forEach((row) => {
        const topics = (row.dataset.topics || '')
          .split(',')
          .map((t) => t.trim())
          .filter(Boolean);
        const show =
          selected.size === 0 || topics.some((t) => selected.has(t));
        row.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      if (empty) empty.classList.toggle('hidden', visible !== 0);
      if (clearBtn) clearBtn.classList.toggle('hidden', selected.size === 0);
    }

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const topic = chip.dataset.topic;
        if (!topic) return;
        if (selected.has(topic)) {
          selected.delete(topic);
          chip.removeAttribute('data-active');
        } else {
          selected.add(topic);
          chip.setAttribute('data-active', '');
        }
        apply();
      });
    });

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        selected.clear();
        chips.forEach((c) => c.removeAttribute('data-active'));
        apply();
      });
    }
  })();
</script>
