---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? '';
const resolvedOgImage = ogImage ?? `${siteOrigin}${base}/og/default.png`;
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <link rel="alternate" type="application/rss+xml" title="AI Features" href={`${import.meta.env.BASE_URL}rss.xml`} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={resolvedOgImage} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-neutral-950 text-neutral-100 antialiased font-sans selection:bg-emerald-500/30">
    <div class="mx-auto max-w-3xl px-6 py-12">
      <header class="mb-12 flex items-center justify-between border-b border-neutral-800 pb-6">
        <a href={import.meta.env.BASE_URL} class="font-mono text-sm tracking-tight text-neutral-300 hover:text-emerald-400">
          <span class="text-emerald-400">$</span> ai-features
        </a>
        <span class="font-mono text-xs text-neutral-500">otisdaley-vg</span>
      </header>
      <main>
        <slot />
      </main>
      <footer class="mt-16 border-t border-neutral-800 pt-6 font-mono text-xs text-neutral-500">
        Built with Astro + Tailwind v4. Source on
        <a href="https://github.com/otisdaley-vg/ai-features" class="text-neutral-300 hover:text-emerald-400">GitHub</a>.
        Subscribe via <a href={`${import.meta.env.BASE_URL}rss.xml`} class="text-neutral-300 hover:text-emerald-400">RSS</a>.
      </footer>
    </div>
    <script>
      import '../scripts/copy-code.ts';
    </script>
  </body>
</html>
